@page
@model Razor.Web.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].Address)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].City)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].State)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].Zip)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].NoOfUnits)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].YearBuilt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].CreatedDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Condo[0].UpdatedDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Condo) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Address)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.City)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.State)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Zip)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.NoOfUnits)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.YearBuilt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UpdatedDate)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
