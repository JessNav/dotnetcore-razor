# Generated .gitignore for .NET / Visual Studio projects

# Build Folders
bin/
obj/
out/

# Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# NuGet
packages/
*.nupkg
project.lock.json
project.fragment.lock.json

# Publish folder
publish/

# IIS Express
/.vs/localhost*/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Database files
*.mdf
*.ldf
*.sqlite
*.db

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Node / front-end
node_modules/
bower_components/

# User-specific files
*.env
*.local
secrets.json

# Rider / ReSharper
_ReSharper*/
*.DotSettings.user

# Coverage and test results
coverage/
*.coverage
*.coveragexml
TestResults/

# JetBrains Rider caches
.idea/

# dotnet tools
.toolstarget

# End of file
